{
  "extends": "./.wxt/tsconfig.json",
  "exclude": ["node_modules"],
  "include": [
    ".wxt/wxt.d.ts",
    "next-env.d.ts",
    "**/*.ts",
    "**/*.d.ts",
    "**/*.tsx",
    "**/*.cjs",
    "**/*.mjs",
    "*.js",
    "*.config.js",
    ".next/types/**/*.ts"
  ],
  "compilerOptions": {
    "strict": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@app/prisma": ["./prisma/generated/client.ts"],
      "@app/prisma/*": ["./prisma/generated/*"],
      "-/*": ["./assets/*"]
    },
  }
}
