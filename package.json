{
  "name": "class-notifier-api",
  "displayName": "USC Schedule Helper",
  "homepage": "https://usc.jonlu.ca",
  "description": "A tool to help you find classes at USC",
  "author": "JonLuca DeCaro <usc-schedule-helper@jonlu.ca>",
  "version": "15.3.2",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production next build && next start",
    "dev": "NODE_ENV=development next dev",
    "lint": "oxlint .",
    "dev:email": "email dev --dir src/emails --port 3001",
    "postinstall": "wxt prepare && prisma generate",
    "typecheck": "tsc --noEmit",
    "monitor": "tsx jobs/monitor.ts",
    "refresh-rmp": "tsx jobs/refreshRmpData.ts && prettier -w src/data",
    "dev:extension": "NODE_ENV=development wxt",
    "build:extension": "NODE_ENV=production wxt build",
    "package:extension": "NODE_ENV=production wxt zip"
  },
  "dependencies": {
    "@ag-grid-community/client-side-row-model": "^32.3.9",
    "@ag-grid-community/core": "^32.3.9",
    "@ag-grid-community/react": "^32.3.9",
    "@aws-sdk/client-ses": "^3.1014.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-email/components": "1.0.10",
    "@react-email/render": "2.0.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.95.0",
    "@tanstack/react-query-devtools": "^5.95.0",
    "@trpc/client": "^11.14.1",
    "@trpc/next": "^11.14.1",
    "@trpc/react-query": "^11.14.1",
    "@trpc/server": "^11.14.1",
    "@types/chrome": "0.1.38",
    "@types/cookie": "^1.0.0",
    "@types/jquery": "^4.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/tough-cookie": "^4.0.5",
    "@types/uuid": "^11.0.0",
