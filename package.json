{
  "name": "class-notifier-api",
  "displayName": "USC Schedule Helper",
  "homepage": "https://usc.jonlu.ca",
  "description": "A tool to help you find classes at USC",
  "author": "JonLuca DeCaro <usc-schedule-helper@jonlu.ca>",
  "version": "15.3.4",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production next build && next start",
    "dev": "NODE_ENV=development next dev",
    "lint": "oxlint .",
    "test": "tsx --test src/server/auth.test.ts src/emails/NowWatchingEmail.test.tsx",
    "dev:email": "email dev --dir src/emails --port 3001",
    "postinstall": "wxt prepare && prisma generate",
    "typecheck": "tsc --noEmit",
    "monitor": "tsx jobs/monitor.ts",
    "refresh-rmp": "tsx jobs/refreshRmpData.ts && prettier -w src/data",
    "dev:extension": "NODE_ENV=development wxt",
    "dev:firefox": "NODE_ENV=development wxt -b firefox --mv3",
    "build:extension": "NODE_ENV=production wxt build",
    "build:firefox": "NODE_ENV=production wxt build -b firefox --mv3",
    "package:extension": "NODE_ENV=production wxt zip",
    "package:firefox": "NODE_ENV=production wxt zip -b firefox --mv3",
    "lint:firefox": "web-ext lint --source-dir .output/firefox-mv3",
    "submit:firefox": "web-ext sign --source-dir .output/firefox-mv3 --channel=listed --amo-metadata=amo-metadata.json --upload-source-code=.output/class-notifier-api-*-sources.zip --artifacts-dir=.output/firefox-signed"
  },
  "dependencies": {
    "@ag-grid-community/client-side-row-model": "^32.3.9",
    "@ag-grid-community/core": "^32.3.9",
    "@ag-grid-community/react": "^32.3.9",
    "@aws-sdk/client-ses": "^3.1079.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@mui/icons-material": "9.2.0",
    "@mui/material": "9.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.10",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@trpc/client": "^11.18.0",
    "@trpc/next": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@types/chrome": "0.2.2",
    "@types/cookie": "^1.0.0",
    "@types/jquery": "^4.0.1",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/tough-cookie": "^4.0.5",
    "@types/uuid": "^11.0.0",
    "@wxt-dev/module-react": "^1.2.2",
    "@wxt-dev/storage": "^1.2.8",
    "ag-grid-community": "^36.0.0",
    "cookie": "^2.0.1",
    "critters": "^0.0.25",
    "cssnano": "^8.0.2",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "email-validator": "^2.0.4",
    "googleapis": "^173.0.0",
    "html-to-text": "^10.0.0",
    "http-cookie-agent": "^8.0.0",
    "imapflow": "^1.4.3",
    "jquery": "^4.0.0",
    "js-cookie": "^3.0.8",
    "lodash-es": "^4.18.1",
    "mailparser": "^3.9.12",
    "moment": "^2.30.1",
    "moment-range": "^4.0.2",
    "next": "^16.2.10",
    "node-gyp": "^13.0.1",
    "p-map": "^7.0.5",
    "pg": "^8.22.0",
    "phone-parser": "0.0.2",
    "postcss": "^8.5.16",
    "postcss-import": "^16.1.1",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "prisma-json-types-generator": "^5.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.6",
    "react-select": "^5.10.2",
    "react-toastify": "^11.1.0",
    "rimraf": "^6.1.3",
    "sharp": "^0.35.3",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.3.2",
    "toad-scheduler": "^4.0.1",
    "tough-cookie": "^6.0.1",
    "tsx": "^4.23.0",
    "twilio": "6.0.2",
    "typescript": "^6.0.3",
    "undici": "^8.7.0",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "wxt": "^0.20.27",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "prettier": {
    "printWidth": 120,
    "arrowParens": "always",
    "semi": true,
    "tabWidth": 2,
    "trailingComma": "all"
  },
  "packageManager": "yarn@4.12.0",
  "resolutions": {
    "next": "16.2.10",
    "shell-quote": "1.8.4",
    "tmp": "0.2.7"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  },
  "devDependencies": {
    "@react-email/preview-server": "^5.2.10",
    "@types/html-to-text": "^9.0.4",
    "@types/mailparser": "^3.4.6",
    "@types/pg": "^8.20.0",
    "oxlint": "^1.72.0",
    "vite": "^8.1.3",
    "web-ext": "^10.4.0"
  }
}
