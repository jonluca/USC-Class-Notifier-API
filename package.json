    "googleapis": "^171.4.0",
    "html-to-text": "^9.0.5",
    "http-cookie-agent": "^7.0.3",
    "imapflow": "^1.2.16",
    "jquery": "^4.0.0",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.23",
    "mailparser": "^3.9.4",
    "moment": "^2.30.1",
    "moment-range": "^4.0.2",
    "next": "^16.2.1",
    "node-gyp": "^12.2.0",
    "p-map": "^7.0.4",
    "pg": "^8.20.0",
