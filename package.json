    "tailwindcss": "^4.2.2",
    "toad-scheduler": "^3.1.0",
    "tough-cookie": "^6.0.1",
    "tsx": "^4.21.0",
    "twilio": "5.13.0",
    "typescript": "^5.9.3",
    "undici": "^7.24.5",
    "uuid": "^13.0.0",
